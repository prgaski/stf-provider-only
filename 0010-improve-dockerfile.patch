From 5c901a63c5b305404f3c871686ac629ccddfb2bc Mon Sep 17 00:00:00 2001
From: Patrick Gaskin <pg7254@outlook.com>
Date: Tue, 13 May 2025 23:17:12 -0400
Subject: [PATCH 10/10] improve dockerfile

---
 Dockerfile | 12 +++++++-----
 1 file changed, 7 insertions(+), 5 deletions(-)

diff --git a/Dockerfile b/Dockerfile
index 0efc43e9..8bdbf66b 100644
--- a/Dockerfile
+++ b/Dockerfile
@@ -1,12 +1,14 @@
-FROM debian:bookworm AS base
+FROM debian:bookworm AS node
 RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends nodejs npm
 
-FROM base AS build
-COPY --link ./ /app/
+FROM node AS deps
+COPY --link ./package.json ./package-lock.json /app/
+COPY --link ./vendor/npm/ /app/vendor/npm/
 WORKDIR /app
 RUN npm install
 
-FROM base
-COPY --link --from=build /app/ /app/
+FROM node
+COPY --link ./ /app/
+COPY --link --from=deps /app/node_modules/ /app/node_modules/
 ENTRYPOINT ["/app/bin/stf"]
 CMD ["provider"]
